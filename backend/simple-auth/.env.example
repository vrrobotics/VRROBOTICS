# Copy to .env and fill in your Supabase connection string.

# Supabase Postgres connection string.
# Supabase dashboard → Project Settings → Database → Connection string → "Session pooler".
# URL-encode special characters in the password (e.g. @ becomes %40).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Port the auth API listens on. Frontend expects http://localhost:8000
# (axiosInstance baseURL = VITE_BASTION_API_URL ?? http://localhost:8000, + /api/v1).
PORT=8000

# Secret used to sign JWT access/refresh tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# Token lifetimes.
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=7d

# Allowed browser origin (the Vite dev server). Comma-separate for multiple.
CORS_ORIGIN=http://localhost:8080
