# ============================================================================
# admin-service env
# ============================================================================
PORT=5000
NODE_ENV=development

# ----- CORS -----------------------------------------------------------------
# Comma-separated allowlist of frontend origins for this public admin+payment
# API. localhost is always allowed. In PROD set this to your deployed frontend:
#   ADMIN_ALLOWED_ORIGINS=https://app.vrroboticsacademy.com
# If left empty in prod, CORS stays open to all origins (a boot warning is logged).
ADMIN_ALLOWED_ORIGINS=

# ----- Supabase Postgres ----------------------------------------------------
# Use the *pooled* connection string for runtime (port 6543) and the *direct*
# one (port 5432) for migrations. Get from Project Settings → Database →
# Connection string → URI.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SCHEMA=lms_admin
AUTH_DB_SCHEMA=lucy_devdb
ASSESSMENT_DB_SCHEMA=lucy_devdb

# Legacy discrete-credential fallback (only used if DATABASE_URL is absent):
DB_HOST=
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=postgres

# ----- Supabase (Auth + JWT verification) -----------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME_with_anon_eyJ...
# Server-only — privileged, bypasses RLS. Never expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_with_service_role_eyJ...
# HS256 secret used to verify Supabase-issued JWTs locally.
# Project Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=REPLACE_ME

# ----- Cloudflare R2 (images / PDFs / docs / assets) ------------------------
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=yagnatech-assets
# Custom domain (or pub-xxxx.r2.dev) fronting the bucket. Stored URLs are
# built from this base + the R2 key.
R2_PUBLIC_URL=https://assets.yagnatech.org

# ----- Bunny Stream (videos) ------------------------------------------------
BUNNY_STREAM_LIBRARY_ID=REPLACE_ME
BUNNY_STREAM_API_KEY=REPLACE_ME
# Pull-zone CDN hostname for the library (e.g. vz-xxxx.b-cdn.net).
BUNNY_STREAM_CDN_HOSTNAME=REPLACE_ME

# ----- Legacy / misc --------------------------------------------------------
UPLOAD_DIR=uploads
APP_URL=http://localhost:5000
LMS_LOGIN_URL=http://localhost:5173/login

# Kept for any remaining direct-JWT consumers (legacy seed scripts).
# New code should NOT use this — verify Supabase JWTs via SUPABASE_JWT_SECRET.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ----- Monitoring (Sentry) --------------------------------------------------
SERVICE_NAME=admin-service
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# SMTP (transactional email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@lms.local

# Shared secret used by sibling services to call internal endpoints.
INTERNAL_API_SECRET=
