PORT=4000
NODE_ENV=development
SERVICE_NAME=admin-service

# Shared MySQL (same RDS used by auth/course/college/payment/assessment/organization)
DB_DIALECT=mysql
DB_HOST="lucy-devdb.cu1kcwwqaaqb.us-east-1.rds.amazonaws.com"
DB_PORT=3306
DB_USER=SimaxLMSAdmin
DB_PASS="1ZXrqIL3D9Dy9pOMDw4T"
DB_NAME=lms_admin
# Read-only handle to auth-service's DB (same RDS, different schema). Used by
# the College Dashboard endpoint to count students/scores per college.
AUTH_DB_NAME=lucy_devdb

UPLOAD_DIR=uploads
APP_URL=http://localhost:4000

# JWT — keep in sync with auth-service's JWT_ACCESS_SECRET so tokens it issues
# are accepted by admin-service's adminOnly middleware.
JWT_SECRET=change-me-access
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@lms.local
