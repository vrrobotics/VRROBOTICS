# ============================================================================
# Bastion (gateway) env
# ============================================================================
PORT=8000
NODE_ENV=development

# Verifies the Supabase access token before proxying to downstream services.
SUPABASE_JWT_SECRET=REPLACE_ME

# Upstream service URLs (used by the proxy router).
AUTH_SERVICE_URL=http://localhost:8001
COURSE_SERVICE_URL=http://localhost:8002
ASSESSMENT_SERVICE_URL=http://localhost:8003
ADMIN_SERVICE_URL=http://localhost:5000
COLLEGE_SERVICE_URL=http://localhost:8005
ORG_SERVICE_URL=http://localhost:8006
PAYMENT_SERVICE_URL=http://localhost:8007

# ----- Monitoring (Sentry) --------------------------------------------------
SERVICE_NAME=bastion
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

BASTION_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
