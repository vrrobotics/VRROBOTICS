# ============================================================================
# backend/.env  — consumed by docker-compose.yml at `up` time.
# Copy to backend/.env on the host (NOT inside any service folder).
#
# Per-service credentials (DATABASE_URL, SUPABASE_*, R2_*, BUNNY_*, SENTRY_DSN)
# live in each service's own .env (see each service's .env.example). This file
# only holds compose-level / gateway-level values.
# ============================================================================

# Comma-separated list of frontend origins allowed by Bastion CORS.
# In production set this to your CloudFront / Cloudflare domain.
BASTION_ALLOWED_ORIGINS=https://app.yourdomain.com

# ----------------------------------------------------------------------------
# Infrastructure note (post-migration):
#   * Database  → Supabase Postgres (external, cloud). No DB container in
#                 docker-compose — every service connects out via DATABASE_URL
#                 set in its own .env.
#   * Auth      → Supabase Auth. Services verify HS256 JWTs with
#                 SUPABASE_JWT_SECRET (set per service .env, and in
#                 Bastion-server/.env so the gateway can fast-fail).
#   * Video     → Bunny Stream (admin-service/.env: BUNNY_STREAM_*).
#   * Assets    → Cloudflare R2 (admin-service/.env: R2_*).
#   * Cache     → (future) Upstash Redis — not wired yet.
#   * Monitoring→ Sentry (each service/.env: SENTRY_DSN) + Grafana/UptimeKuma
#                 scraping the /health endpoints each service exposes.
# ----------------------------------------------------------------------------
