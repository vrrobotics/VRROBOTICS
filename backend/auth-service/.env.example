# ============================================================================
# auth-service env
# ============================================================================
PORT=8001
NODE_ENV=development

# ----- Supabase Postgres ----------------------------------------------------
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SCHEMA=lucy_devdb

# ----- Supabase (Auth) ------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME_with_anon_eyJ...
# Server-only. Used to provision admin/student users via the admin API.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_with_service_role_eyJ...
# HS256 secret used to verify Supabase-issued JWTs locally.
SUPABASE_JWT_SECRET=REPLACE_ME

# ----- Monitoring (Sentry) --------------------------------------------------
# Leave blank to disable. SERVICE_NAME tags events in Sentry/Grafana.
SERVICE_NAME=auth-service
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# ----- CORS -----------------------------------------------------------------
# Comma-separated list of allowed frontend origins. The code reads CORS_ORIGINS
# first, then ALLOWED_ORIGINS. In PROD set this to your deployed frontend, e.g.
#   CORS_ORIGINS=https://app.vrroboticsacademy.com
# If left empty in prod, browser logins are CORS-blocked (curl still works).
CORS_ORIGINS=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
