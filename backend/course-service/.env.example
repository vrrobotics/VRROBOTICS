# ============================================================================
# course-service env
# ============================================================================
PORT=8002
NODE_ENV=development

DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SCHEMA=lucy_devdb

# Verifies Supabase-issued access tokens on protected routes.
SUPABASE_JWT_SECRET=REPLACE_ME

# Used by course/clg validation when calling college-service.
COLLEGE_SERVICE_HOST=http://localhost:8005
COLLEGE_SERVICE_PORT=8005

# ----- Monitoring (Sentry) --------------------------------------------------
SERVICE_NAME=course-service
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
