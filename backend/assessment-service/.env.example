# ============================================================================
# assessment-service env
# ============================================================================
PORT=8003
NODE_ENV=development

DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SCHEMA=lucy_devdb

SUPABASE_JWT_SECRET=REPLACE_ME

# Outbound call to admin-service /api/internal/email/enqueue for confirmation
# emails. Must match INTERNAL_API_SECRET in admin-service/.env.
ADMIN_SERVICE_URL=http://localhost:5000
INTERNAL_API_SECRET=

# ----- Monitoring (Sentry) --------------------------------------------------
SERVICE_NAME=assessment-service
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
