# ============================================================================
# frontend (Vite) env
# ============================================================================

# Backend gateway
VITE_BASTION_API_URL=http://localhost:8000

# Direct-to-admin URL used by some admin screens that bypass Bastion.
VITE_ADMIN_API_URL=http://localhost:5000

# Supabase client (anon key only — service_role NEVER goes here)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_ME_with_anon_eyJ...

# Video CDN base (Bunny Stream). Used by lesson player to construct HLS /
# embed URLs from the GUID stored in DB if/when the frontend bypasses the
# admin-built embed_url.
VITE_BUNNY_STREAM_CDN_HOSTNAME=
VITE_BUNNY_STREAM_LIBRARY_ID=

# R2 public URL (assets like thumbnails / banners / certificates).
VITE_R2_PUBLIC_URL=https://assets.yagnatech.org

# Monitoring (Sentry browser SDK). Leave blank to disable.
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_RELEASE=

VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
