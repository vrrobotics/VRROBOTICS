PORT=4000
NODE_ENV=development

# Point at the same MySQL DB Laravel uses
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lms_cp
DB_USER=root
DB_PASSWORD=

# JWT — generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# LMS settings (parallels get_settings() in Laravel)
STUDENT_EMAIL_VERIFICATION=0
DEVICE_LIMITATION=1

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="LMS <noreply@example.com>"

# URLs
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads
PUBLIC_URL_PREFIX=/uploads

# Payments (optional — per gateway)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
